# App Config
SECRET_KEY=your-secret-key-min-32-chars
DEBUG=false

# Database — Neon (recommended)
# Get connection string from Neon dashboard → Connection details → pooled connection
# Use asyncpg driver for this app (replace postgresql:// with postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?ssl=require

# Optional: local Postgres via Docker (profile: local-db)
# DATABASE_URL=postgresql+asyncpg://searchmind:your-db-password@postgres/searchmind

# Cache Configuration
REDIS_URL=redis://redis:6379/0

# Search Providers (Optional if falling back to DuckDuckGo)
BRAVE_API_KEY=your-brave-api-key
SERPAPI_KEY=your-serpapi-key-optional

# LLM Configuration
LLM_PROVIDER=groq
LLM_API_KEY=your-llm-api-key
LLM_MODEL=llama-3.3-70b-specdec
LLM_BASE_URL=https://api.groq.com/openai/v1

# Crawl
CRAWL_MAX_CONTENT_LENGTH=8000

# Operations
RUN_MIGRATIONS_ON_STARTUP=true
REQUIRE_REDIS_FOR_RATE_LIMIT=true
PURGE_EXPIRED_CACHE_ON_STARTUP=true
